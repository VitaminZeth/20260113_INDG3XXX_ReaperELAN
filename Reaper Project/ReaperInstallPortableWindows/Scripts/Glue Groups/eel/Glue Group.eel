function glueGroup()
(

	PreventUIRefresh(1);

	// select whole group if its in one
	Main_OnCommand(40034, 0);

	//if we are dealing with more than one item, proceed
	num_items = CountSelectedMediaItems(0);
	num_items > 1 ? (

		Undo_BeginBlock();

		// group items anyway in case theres new items added
		Main_OnCommand(40032, 0);

		// store a reference to the original item
		source_item = GetSelectedMediaItem(0, 0);

		// store a pointer to the original track
		source_track = GetMediaItemTrack(source_item);

		// is this a reglueing of a previously glued item?
		checker.checkForGlueGroup();

		checker.glue_group ? (
			reGlue(source_track, source_item, checker.glue_group, checker.item);
		) : (
			doGlue(source_track, source_item, 0, 0);
		);


		// clean up
		UpdateTimeline();
		UpdateArrange();
		TrackList_AdjustWindows(1);

		// zoom in then out
		// Main_OnCommand(1011, 0);
		// Main_OnCommand(1012, 0);

		Undo_EndBlock("Glue Group", -1);

	);

	PreventUIRefresh(-1);

);




// do the actual glue
glueGroup();

