
function getSetObjectState(obj, state, minimal) local (fastStr, set)
(
	fastStr = extension_api("SNM_CreateFastString", state);
	set = strlen(state) > 0 ? 1 : 0;
	
	extension_api("SNM_GetSetObjectState", obj, fastStr, set, minimal);

	extension_api("SNM_GetFastString", #state, fastStr);
	extension_api("SNM_DeleteFastString", fastStr);
	#state;
);

function setToAudioTake(item) local (num_takes, active_take, active_take_number)
(
	// make sure everything is deselected
	deselect();
	
	num_takes = GetMediaItemNumTakes(item);

	num_takes > 0 ? (
		(active_take = GetActiveTake(item)) ? (

			take_source = GetMediaItemTake_Source(active_take);

			GetMediaSourceType(take_source, #take_type);
			
			match("MIDI", #take_type) ? (

				// store ref to the original active take for unglueing
				active_take_number = GetMediaItemTakeInfo_Value(active_take, "IP_TAKENUMBER");
				// convert the active MIDI item to an audio take
				SetMediaItemSelected(item, 1);
				Main_OnCommand(40209, 0);

				SetActiveTake(GetTake(item, num_takes));
				active_take = GetActiveTake(item);
				#take_name = "glue_group_render:";
				#take_name += sprintf(#, "%d", active_take_number);
				GetSetMediaItemTakeInfo_String(active_take, "P_NAME", #take_name, 1);
				SetMediaItemSelected(item, 0);

				cleanNullTakes(item);
			);
		);
	);
);

function restoreOriginalTake(item) local (num_takes, active_take, take_name, take_number)
(
	// make sure everything is deselected
	deselect();

	num_takes = GetMediaItemNumTakes(item);
	
	num_takes > 0 ? (
		(active_take = GetActiveTake(item)) ? (

			take_name = GetTakeName(active_take)
			
			match("glue_group_render:%d", take_name, take_number) ? (
				// delete this take
				SetMediaItemSelected(item, 1);
				Main_OnCommand(40129, 0);
				// reselect original active take
				take_number ? (
					original_take = GetTake(item, take_number);	
					SetActiveTake(original_take);
				);

				SetMediaItemSelected(item, 0);

				cleanNullTakes(item);
			);
		);
	);
);

function cleanNullTakes(item, state, force)
(
	#state = strlen(state) > 0 ? state : getSetObjectState(item, "", 0);

	match("TAKE NULL", state) || force ? (
		#state = ("TAKE NULL", "");
		getSetObjectState(item, state, 0);
	);
);

function setItemGlueGroup(item, glue_group, not_container) local(key, take)
(
	key = not_container ? "glue_group:" : "glue_group_container:";

	#notes = "";
	#notes += key;
	#notes += sprintf(#, "%d", glue_group);

	ShowConsoleMsg(#notes);
	ShowConsoleMsg("\n");

	extension_api("ULT_SetMediaItemNote", item, #notes);

	(take = GetActiveTake(item)) ? GetSetMediaItemTakeInfo_String(take, "P_NAME", #notes, 1);
);


function getGlueGroupFromItem(item) local (take)
(
	// use the SWS ULT extension to get the notes
	extension_api("ULT_GetMediaItemNote", #notes, item);

	// if theres no notes, it might be in the name of the active take
	strlen(#notes) < 1 ? (
		(take = GetActiveTake(item)) ? GetSetMediaItemTakeInfo_String(take, "P_NAME", #notes, 0);
	);

	// check for the glue group container string and store the int in 'glue_group'
	match("*glue_group*?:%d*", #notes, glue_group);

	// return the glue group, or 0 if not found
	glue_group;
);

function checkForGlueGroup() local(i)
(
	this.glue_group = 0;

	i = 0;
	while(i < num_items && this.glue_group == 0)
	(
		this.item = GetSelectedMediaItem(0, i);
		this.glue_group = getGlueGroupFromItem(this.item);
		i += 1;
	);
);




function doGlue(source_track, source_item, glue_group, existing_container) local(i, item, key)
(
	ShowConsoleMsg("\ndoGlue");
	
	// make a new glue_group id from the group id if this is a new group,
	glue_group == 0 ? glue_group = GetMediaItemInfo_Value(source_item, "I_GROUPID");

	#stored_states = "";
	
	i = 0;
	loop(num_items,
		item = GetSelectedMediaItem(0, i);
		items[i] = item;
		#stored_states += getSetObjectState(item, "", 0);
		#stored_states += "|||";
		i += 1;
	);

	ShowConsoleMsg(#stored_states);

	// store the states in the project
	key = sprintf(#, "%d", glue_group);
	SetProjExtState(0, "GLUE_GROUPS", key, #stored_states);

	GetProjExtState(0, "GLUE_GROUPS", "GROUPS", #groups);
	#key = "|";
	#key += key;
	#key += "|";

	match(#key, #groups) == 0 ? (
		#groups += #key;
		SetProjExtState(0, "GLUE_GROUPS", "GROUPS", #groups);
	)
	

